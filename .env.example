# Copy to .env and fill in from Supabase dashboard -> Project Settings -> API.
# Vite only exposes VITE_-prefixed vars to the browser bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only — used by supabase/seed.mjs, never shipped to the client.
SUPABASE_SERVICE_ROLE_KEY=

# capture/crawl.mjs — base URL to crawl and a login for authenticated steps.
CAPTURE_BASE_URL=http://localhost:5173
CAPTURE_LOGIN_EMAIL=
CAPTURE_LOGIN_PASSWORD=
